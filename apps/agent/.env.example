# ┌──────────────────────────────────────────────────────────────┐
# │  ListPack Agent (apps/agent) — env vars                      │
# │  Copy to .env and fill in values                             │
# └──────────────────────────────────────────────────────────────┘

# ── Service ───────────────────────────────────────────────────
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
# Shared token between web ↔ agent (must match apps/web AGENT_SERVICE_TOKEN)
AGENT_SERVICE_TOKEN=dev-shared-token-replace-me

# ── LangGraph Checkpointer ────────────────────────────────────
# sqlite for local dev; switch to postgres in staging/prod
CHECKPOINT_BACKEND=sqlite
CHECKPOINT_PATH=./checkpoints.sqlite

# ── Database (D2+, share with apps/web) ───────────────────────
POSTGRES_URL=postgresql://postgres:postgres@localhost:54322/listpack

# ── LLM / Model APIs (via sparkcode proxy) ────────────────────
SPARKCODE_API_BASE=https://api.sparkcode.top/v1
SPARKCODE_API_KEY=
# Default models per task (override per-call as needed)
LLM_PLANNER_MODEL=claude-sonnet-4-6
LLM_SCENE_JSON_MODEL=claude-sonnet-4-6
LLM_CRITIC_MODEL=gpt-4o
IMAGE_GEN_MODEL=nano-banana

# ── Replicate (SAM / LaMa / etc, D2+) ─────────────────────────
REPLICATE_API_TOKEN=

# ── Object Storage (R2, D2+) ──────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=listpack-dev
