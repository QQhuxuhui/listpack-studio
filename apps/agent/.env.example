# ─── ListPack Studio — apps/agent env template ───────────────────────
# Copy to `.env` and fill in real values. Never commit .env.

# ── Database (required: rules + agent_runs persistence + quota) ─────
POSTGRES_URL=postgres://listpack:dev_only@localhost:5432/listpack

# ── Service-to-service auth ─────────────────────────────────────────
# Shared HMAC token — must match apps/web's AGENT_SERVICE_TOKEN.
# Leave empty for local dev convenience (web routes also skip when empty).
AGENT_SERVICE_TOKEN=replace-me

# ── Networking ──────────────────────────────────────────────────────
AGENT_HOST=0.0.0.0
AGENT_PORT=8000

# ── Storage (must match apps/web STORAGE_ROOT when on the same host) ─
STORAGE_ROOT=./storage

# ── Model router (Sparkcode OpenAI-compatible gateway) ──────────────
# Without these, the router falls back to mock clients — compliance/check
# and /v1/hello/stream still work, but agent runs won't produce real images.
# SPARKCODE_BASE_URL=https://api.sparkcode.top/v1
# SPARKCODE_API_KEY=sk-...

# Default models per role (override per-call as needed).
# LLM_PLANNER_MODEL=claude-sonnet-4-6
# LLM_SCENE_JSON_MODEL=claude-sonnet-4-6
# LLM_CRITIC_MODEL=gpt-4o
# IMAGE_GEN_MODEL=nano-banana

# ── Observability ───────────────────────────────────────────────────
LOG_LEVEL=info
# json | text — json emits one structured line per log record for shippers.
LOG_FORMAT=text
# SENTRY_DSN=https://...@sentry.io/...
