# ┌──────────────────────────────────────────────────────────────┐
# │  ListPack Web (apps/web) — env vars                          │
# │  Copy to .env (NOT .env.local) and fill in values            │
# └──────────────────────────────────────────────────────────────┘

# ── Database ──────────────────────────────────────────────────
# Postgres (Neon / Supabase / local docker)
POSTGRES_URL=postgresql://postgres:postgres@localhost:54322/listpack

# ── Auth ──────────────────────────────────────────────────────
# Random 32+ char string. Generate: `openssl rand -base64 32`
AUTH_SECRET=replace-me-with-random-32-char-string

# ── App ───────────────────────────────────────────────────────
BASE_URL=http://localhost:3000

# ── Agent Service ─────────────────────────────────────────────
# Python LangGraph service URL (apps/agent), default local
AGENT_SERVICE_URL=http://localhost:8000
# Shared secret between web ↔ agent for service-to-service auth
AGENT_SERVICE_TOKEN=dev-shared-token-replace-me

# ── Stripe (D5+, leave blank for D1-D4) ───────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Object Storage (Cloudflare R2, D2+) ───────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=listpack-dev
R2_PUBLIC_URL=

# ── Image Model APIs (used by agent service, here for reference) ─
SPARKCODE_API_BASE=https://api.sparkcode.top/v1
SPARKCODE_API_KEY=
REPLICATE_API_TOKEN=
