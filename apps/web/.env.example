# ─── ListPack Studio — apps/web env template ─────────────────────────
# Copy to `.env` and fill in real values. Never commit .env.

# ── Database (required) ─────────────────────────────────────────────
# Drizzle ORM connection string. Use the dedicated listpack_app user in
# prod (not the postgres superuser).
POSTGRES_URL=postgres://listpack:dev_only@localhost:5432/listpack

# ── Session / token signing (required) ──────────────────────────────
# 32+ random bytes; openssl rand -hex 32
AUTH_SECRET=replace-me-with-openssl-rand-hex-32

# Optional override for password-reset JWT signing key. Defaults to AUTH_SECRET.
# RESET_SECRET=

# ── Agent service (required) ────────────────────────────────────────
AGENT_SERVICE_URL=http://localhost:8000
# Shared HMAC token web ↔ agent; must match apps/agent's AGENT_SERVICE_TOKEN.
AGENT_SERVICE_TOKEN=replace-me

# ── Stripe (live payments) ──────────────────────────────────────────
# See docs/DEPLOYMENT.md § Stripe — create 4 products named exactly:
#   Free / Starter / Pro / Brand
# Prices: Free $0, Starter $19, Pro $49, Brand $149 (per month)
STRIPE_SECRET_KEY=sk_live_or_test
STRIPE_WEBHOOK_SECRET=whsec_...
# Public site URL — Stripe returns the user here after checkout.
BASE_URL=http://localhost:3000

# ── Email (Resend) ──────────────────────────────────────────────────
# Optional: when unset, signup / invitation / reset emails log-only.
# RESEND_API_KEY=re_...
# EMAIL_FROM="ListPack <hi@your-domain.com>"

# ── Shopify (OAuth, optional) ───────────────────────────────────────
# Enables /dashboard/connections install flow. From Shopify Partners.
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHOPIFY_SCOPES=read_products,write_products,write_files
# SHOPIFY_REDIRECT_URI=http://localhost:3000/api/shopify/oauth/callback

# Token encryption for platform_connections.encrypted_access_token.
# Falls back to AUTH_SECRET / STRIPE_SECRET_KEY but production should
# rotate this independently.
# PLATFORM_TOKEN_ENCRYPTION_KEY=replace-me-32-bytes

# ── Storage backend ─────────────────────────────────────────────────
# 'local' (default) writes to ./storage. Set 's3' once S3Storage is
# implemented in lib/storage/index.ts.
# STORAGE_BACKEND=local
STORAGE_ROOT=./storage

# ── Admin views ─────────────────────────────────────────────────────
# Comma-separated emails permitted to access /admin.
# ADMIN_USER_EMAILS=alice@your-domain.com,bob@your-domain.com

# ── Observability ───────────────────────────────────────────────────
LOG_LEVEL=info
# SENTRY_DSN=https://...@sentry.io/...
